{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/handlers/**/*",
    "src/types/*.d.ts",
    "src/utils/*.ts",
    "src/constants/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
